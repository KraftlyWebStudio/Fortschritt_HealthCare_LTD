{
  "name": "fortschritt-healthcare",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Fortschritt Healthcare",
  "scripts": {
    "dev": "concurrently -c \"cyan,magenta,yellow\" \"pnpm --filter frontend run dev\" \"pnpm --filter backend run dev\" \"pnpm --filter backend exec prisma studio\"",
    "build": "pnpm -r run build",
    "start": "pnpm -r run start"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@prisma/client": "^7.7.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prisma": "^7.5.0"
  }
}
